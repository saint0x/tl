{
  "version": 1,
  "name": "test-git-parity-explore",
  "distributed": {
    "node_count": 3,
    "steps": [
      { "type": "client_put", "node": "n0", "key": "test_git_parity", "value": "v1" },
      { "type": "client_put", "node": "n1", "key": "test_git_parity", "value": "v1" },
      { "type": "client_put", "node": "n2", "key": "test_git_parity", "value": "v1" },
      { "type": "partition", "a": "n1", "b": "n2" },
      { "type": "tick", "duration": "10ms" },
      { "type": "heal", "a": "n1", "b": "n2" },
      { "type": "tick", "duration": "10ms" }
    ],
    "invariants": [
      { "type": "kv_present_on_all", "key": "test_git_parity" },
      { "type": "kv_all_equal", "key": "test_git_parity" }
    ]
  }
}
