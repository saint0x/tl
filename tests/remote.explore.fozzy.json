{
  "version": 1,
  "name": "remote-explore",
  "distributed": {
    "node_count": 3,
    "steps": [
      { "type": "client_put", "node": "n0", "key": "remote", "value": "v1" },
      { "type": "client_put", "node": "n1", "key": "remote", "value": "v1" },
      { "type": "client_put", "node": "n2", "key": "remote", "value": "v1" },
      { "type": "crash", "node": "n1" },
      { "type": "tick", "duration": "10ms" },
      { "type": "restart", "node": "n1" },
      { "type": "tick", "duration": "10ms" }
    ],
    "invariants": [
      { "type": "kv_present_on_all", "key": "remote" },
      { "type": "kv_all_equal", "key": "remote" }
    ]
  }
}
