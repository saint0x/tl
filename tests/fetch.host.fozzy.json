{
  "version": 1,
  "name": "fetch-host",
  "steps": [
    { "type": "fs_write", "path": "tmp/fetch/host.txt", "data": "fetch-host" },
    { "type": "fs_read_assert", "path": "tmp/fetch/host.txt", "equals": "fetch-host" },
    {
      "type": "proc_when",
      "cmd": "echo",
      "args": ["fetch-host"],
      "exit_code": 0,
      "stdout": "fetch-host\n"
    },
    {
      "type": "proc_spawn",
      "cmd": "echo",
      "args": ["fetch-host"],
      "expect_exit": 0,
      "expect_stdout": "fetch-host\n"
    }
  ]
}
