{
  "version": 1,
  "name": "data-access-explore",
  "distributed": {
    "node_count": 3,
    "steps": [
      { "type": "client_put", "node": "n0", "key": "data_access", "value": "v1" },
      { "type": "client_put", "node": "n1", "key": "data_access", "value": "v1" },
      { "type": "client_put", "node": "n2", "key": "data_access", "value": "v1" },
      { "type": "partition", "a": "n0", "b": "n2" },
      { "type": "tick", "duration": "10ms" },
      { "type": "heal", "a": "n0", "b": "n2" },
      { "type": "tick", "duration": "10ms" }
    ],
    "invariants": [
      { "type": "kv_present_on_all", "key": "data_access" },
      { "type": "kv_all_equal", "key": "data_access" }
    ]
  }
}
