{
  "version": 1,
  "name": "platform-linux-explore",
  "distributed": {
    "node_count": 3,
    "steps": [
      { "type": "client_put", "node": "n0", "key": "platform_linux", "value": "v1" },
      { "type": "client_put", "node": "n1", "key": "platform_linux", "value": "v1" },
      { "type": "client_put", "node": "n2", "key": "platform_linux", "value": "v1" },
      { "type": "partition", "a": "n0", "b": "n1" },
      { "type": "tick", "duration": "10ms" },
      { "type": "heal", "a": "n0", "b": "n1" },
      { "type": "tick", "duration": "10ms" }
    ],
    "invariants": [
      { "type": "kv_present_on_all", "key": "platform_linux" },
      { "type": "kv_all_equal", "key": "platform_linux" }
    ]
  }
}
